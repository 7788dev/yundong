generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int                 @id @default(autoincrement())
  username      String              @unique
  passwordHash  String
  role          String              @default("user")
  gender        String?
  age           Int?
  createdAt     DateTime            @default(now())
  sessions      AssessmentSession[]
  plans         RehabPlan[]
  progressLogs  ProgressLog[]
  reassessments Reassessment[]
}

model QuestionBank {
  id           Int                @id @default(autoincrement())
  code         String             @unique
  category     String
  questionText String
  answerType   String             @default("single")
  weight       Float              @default(1)
  enabled      Boolean            @default(true)
  createdAt    DateTime           @default(now())
  options      QuestionOption[]
  answers      AssessmentAnswer[]
}

model QuestionOption {
  id         Int                @id @default(autoincrement())
  questionId Int
  optionText String
  score      Float
  sort       Int                @default(0)
  question   QuestionBank       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@index([questionId])
}

model ActionLibrary {
  id                Int             @id @default(autoincrement())
  code              String          @unique
  name              String
  targetProblem     String
  level             String          @default("beginner")
  contraindications String?
  steps             String
  durationSec       Int             @default(30)
  sets              Int             @default(2)
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now())
  planItems         RehabPlanItem[]
}

model RuleEngineRule {
  id               Int      @id @default(autoincrement())
  ruleName         String
  problemType      String
  conditionJson    String
  scoreFormula     String?
  planTemplateJson String?
  priority         Int      @default(0)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model AssessmentSession {
  id                     Int                  @id @default(autoincrement())
  userId                 Int
  status                 String               @default("started")
  questionnaireScoreJson String?
  poseScoreJson          String?
  finalScoreJson         String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers                AssessmentAnswer[]
  photos                 PosePhoto[]
  poseResults            PoseAnalysisResult[]
  diagnosisResults       DiagnosisResult[]
  plans                  RehabPlan[]
  baselineReassessments  Reassessment[]       @relation("BaselineSession")
  currentReassessments   Reassessment[]       @relation("CurrentSession")

  @@index([userId])
}

model AssessmentAnswer {
  id         Int               @id @default(autoincrement())
  sessionId  Int
  questionId Int
  optionId   Int?
  rawValue   String?
  score      Float             @default(0)
  createdAt  DateTime          @default(now())
  session    AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   QuestionBank      @relation(fields: [questionId], references: [id])
  option     QuestionOption?   @relation(fields: [optionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
}

model PosePhoto {
  id         Int               @id @default(autoincrement())
  sessionId  Int
  viewType   String
  filePath   String
  uploadedAt DateTime          @default(now())
  session    AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PoseAnalysisResult {
  id            Int               @id @default(autoincrement())
  sessionId     Int
  modelName     String?
  modelVersion  String?
  landmarksJson String?
  metricsJson   String?
  confidence    Float             @default(0)
  fallbackUsed  Boolean           @default(false)
  createdAt     DateTime          @default(now())
  session       AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model DiagnosisResult {
  id           Int               @id @default(autoincrement())
  sessionId    Int
  problemType  String
  severity     String
  evidenceJson String?
  adviceText   String?
  createdAt    DateTime          @default(now())
  session      AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model RehabPlan {
  id        Int               @id @default(autoincrement())
  sessionId Int
  userId    Int
  startDate DateTime          @default(now())
  weeks     Int               @default(4)
  summary   String?
  createdAt DateTime          @default(now())
  session   AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     RehabPlanItem[]

  @@index([sessionId])
  @@index([userId])
}

model RehabPlanItem {
  id               Int           @id @default(autoincrement())
  planId           Int
  weekNo           Int
  dayNo            Int
  actionId         Int
  prescriptionJson String?
  notes            String?
  createdAt        DateTime      @default(now())
  plan             RehabPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  action           ActionLibrary @relation(fields: [actionId], references: [id])
  logs             ProgressLog[]

  @@index([planId])
}

model ProgressLog {
  id         Int           @id @default(autoincrement())
  userId     Int
  planItemId Int
  done       Boolean       @default(false)
  painLevel  Int?
  feedback   String?
  loggedAt   DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  planItem   RehabPlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planItemId])
}

model Reassessment {
  id                Int               @id @default(autoincrement())
  userId            Int
  baselineSessionId Int
  currentSessionId  Int
  improvementJson   String?
  createdAt         DateTime          @default(now())
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  baselineSession   AssessmentSession @relation("BaselineSession", fields: [baselineSessionId], references: [id], onDelete: Cascade)
  currentSession    AssessmentSession @relation("CurrentSession", fields: [currentSessionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}